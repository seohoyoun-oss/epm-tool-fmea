# Anthropic Application Programming Interface key.
# In local development, copy this file to .env and fill in the value.
# In production on Vercel, set this in Project Settings -> Environment Variables.
# The key must NEVER be committed to git. It must NEVER be prefixed with VITE_,
# because the VITE_ prefix exposes variables to the browser bundle.
ANTHROPIC_API_KEY=sk-ant-your-key-here
